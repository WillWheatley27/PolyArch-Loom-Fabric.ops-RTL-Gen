// {{ module_name }}.sv -- Fabric FU for share group sqrt_rsqrt.
// op_list: {{ op_list | join(', ') }}
//   op_sel = 0 -> out = sqrt(x)    ({{ op_list[0] }})
//   op_sel = 1 -> out = rsqrt(x)   ({{ op_list[1] }})  1/sqrt(x)
//
// One shared polynomial core; op_sel selects sqrt vs rsqrt coefficients and the
// exponent sign. op_sel held config. Unary op. Intrinsic latency 1.
//
// APPROXIMATE. COMPILE-TIME MINIMAX POLYNOMIAL (Horner), not a ROM: the generator
// fits sqrt(1+f) and 1/sqrt(1+f) over f in [0,1) per format and bakes the signed
// fixed-point coefficients below. For x = 1.m * 2^e (e = 2q + r):
//   sqrt  = [P_sqrt(f)  * (r?sqrt2:1)]   * 2^q
//   rsqrt = [P_rsqrt(f) * (r?1/sqrt2:1)] * 2^-q
// with f = m (fraction). Result normalized to [1,2), clz-free encode (RNE).
// PARAMETERIZED (EXP_W, MANT_W): fp32 (8,23) default, fp64 (11,52), bf16 (8,7).
// Specials: x<0 -> NaN, sqrt(+/-0)=+/-0, rsqrt(+0)=+Inf/rsqrt(-0)=-Inf,
// sqrt(+Inf)=+Inf, rsqrt(+Inf)=+0. Subnormals FTZ.

module {{ module_name }} #(
  parameter  int unsigned EXP_W  = {{ fmt.exp_w }},
  parameter  int unsigned MANT_W = {{ fmt.mant_w }},
  localparam int unsigned WIDTH  = EXP_W + MANT_W + 1,
  localparam int unsigned FRAC   = MANT_W + 4,        // poly datapath fractional bits
  localparam int unsigned CW     = FRAC + 4,          // coefficient width (signed)
  localparam int unsigned BIAS   = (1 << (EXP_W - 1)) - 1,
  localparam int unsigned EXP_MAX = (1 << EXP_W) - 1,
  localparam int unsigned SQRT_DEG  = {{ poly.sqrt_deg }},
  localparam int unsigned RSQRT_DEG = {{ poly.rsqrt_deg }}
) (
  input  logic              clk,
  input  logic              rst_n,

  input  logic              op_sel,     // 0 = {{ op_list[0] }} (sqrt), 1 = {{ op_list[1] }} (rsqrt)

  input  logic [WIDTH-1:0]  in_data_0,  // x
  input  logic              in_valid_0,
  output logic              in_ready_0,

  output logic [WIDTH-1:0]  out_data,
  output logic              out_valid,
  input  logic              out_ready
);

  localparam logic [WIDTH-1:0] QNAN   = {1'b0, {EXP_W{1'b1}}, 1'b1, {(MANT_W-1){1'b0}}};
  localparam logic [WIDTH-1:0] POSINF = {1'b0, {EXP_W{1'b1}}, {MANT_W{1'b0}}};
  localparam logic [WIDTH-1:0] NEGINF = {1'b1, {EXP_W{1'b1}}, {MANT_W{1'b0}}};

  // compile-time minimax coefficients (Q signed, FRAC fractional bits)
  localparam logic signed [CW-1:0] SQRT_C  [0:SQRT_DEG]  = '{ {{ poly.sqrt_coef_lits  | join(', ') }} };
  localparam logic signed [CW-1:0] RSQRT_C [0:RSQRT_DEG] = '{ {{ poly.rsqrt_coef_lits | join(', ') }} };
  localparam logic [FRAC+1:0] SQRT2_Q    = {{ poly.sqrt2_lit }};    // sqrt(2)   in Q.FRAC
  localparam logic [FRAC+1:0] INVSQRT2_Q = {{ poly.invsqrt2_lit }}; // 1/sqrt(2) in Q.FRAC

  logic              s, nan_in, inf_in, zero_in, neg_in;
  logic [EXP_W-1:0]  e_in;
  logic [MANT_W-1:0] m_in;
  logic signed [15:0] e, q, qexp, biased, be;
  logic              r_odd, addexp_m1;
  logic [FRAC-1:0]   f_q;
  // verilator lint_off UNUSEDSIGNAL
  logic signed [CW-1:0]   acc, base;
  logic signed [2*CW:0]   mul;
  logic [CW-1:0]          base_u;   // base magnitude (base is always > 0 here)
  logic [2*CW:0]          prodf;    // unsigned base*factor product
  logic [FRAC+1:0]        mf, mf_n;
  logic [FRAC+1:0]        factor;
  logic [MANT_W:0]        mant24;
  // verilator lint_on UNUSEDSIGNAL
  logic [MANT_W-1:0] mant, mant_f;
  logic              guard, sticky, roundup;
  logic [WIDTH-1:0]  core_enc, conv_result;
  integer            i;

  always_comb begin : datapath
    s = in_data_0[WIDTH-1]; e_in = in_data_0[WIDTH-2:MANT_W]; m_in = in_data_0[MANT_W-1:0];
    nan_in  = (&e_in) & (|m_in);
    inf_in  = (&e_in) & (~|m_in);
    zero_in = (e_in == '0);                    // FTZ
    neg_in  = s & ~zero_in;

    e     = signed'(16'(e_in)) - signed'(16'(BIAS));
    q     = e >>> 1;
    r_odd = e[0];
    qexp  = op_sel ? -q : q;
    f_q   = {m_in, {(FRAC-MANT_W){1'b0}}};     // f in Q0.FRAC

    // Horner: P_sqrt(f)
    acc = SQRT_C[SQRT_DEG];
    for (i = SQRT_DEG - 1; i >= 0; i = i - 1) begin
      mul = acc * $signed({1'b0, f_q});
      acc = CW'(mul >>> FRAC) + SQRT_C[i];
    end
    base = acc;
    if (op_sel) begin
      acc = RSQRT_C[RSQRT_DEG];
      for (i = RSQRT_DEG - 1; i >= 0; i = i - 1) begin
        mul = acc * $signed({1'b0, f_q});
        acc = CW'(mul >>> FRAC) + RSQRT_C[i];
      end
      base = acc;
    end

    // odd-exponent factor (sqrt2 / invsqrt2), then normalize to [1,2).
    // base is always positive here -> use an unsigned product + logical shift.
    factor = op_sel ? INVSQRT2_Q : SQRT2_Q;
    base_u = $unsigned(base);
    prodf  = base_u * factor;
    mf     = r_odd ? (FRAC+2)'(prodf >> FRAC) : (FRAC+2)'(base_u);
    if (mf[FRAC]) begin mf_n = mf;       addexp_m1 = 1'b0; end
    else          begin mf_n = mf << 1;  addexp_m1 = 1'b1; end
    biased = qexp - (addexp_m1 ? 16'sd1 : 16'sd0) + signed'(16'(BIAS));

    // encode (mf_n in [1,2), leading 1 at bit FRAC) -> binary32, RNE
    mant    = mf_n[FRAC-1 -: MANT_W];
    guard   = mf_n[FRAC-MANT_W-1];             // = mf_n[3]
    sticky  = |mf_n[FRAC-MANT_W-2 : 0];        // = |mf_n[2:0]
    roundup = guard & (sticky | mant[0]);
    mant24  = {1'b0, mant} + (MANT_W+1)'(roundup);
    if (mant24[MANT_W]) begin mant_f = '0;             be = biased + 16'sd1; end
    else                begin mant_f = mant24[MANT_W-1:0]; be = biased;      end
    if (be >= signed'(16'(EXP_MAX)))  core_enc = POSINF;
    else if (be <= 16'sd0)            core_enc = {WIDTH{1'b0}};
    else                              core_enc = {1'b0, be[EXP_W-1:0], mant_f};

    // specials
    if (nan_in)        conv_result = QNAN;
    else if (neg_in)   conv_result = QNAN;                       // x < 0
    else if (inf_in)   conv_result = op_sel ? {WIDTH{1'b0}} : POSINF;
    else if (zero_in)  conv_result = op_sel ? (s ? NEGINF : POSINF) : {s, {(WIDTH-1){1'b0}}};
    else               conv_result = core_enc;
  end : datapath

  // ---- latency-1 handshake (unary) ----
  logic fire;
  assign fire       = in_valid_0 & (~out_valid | out_ready);
  assign in_ready_0 = fire;

  always_ff @(posedge clk) begin : pipe
    if (!rst_n) begin
      out_valid <= 1'b0; out_data <= {WIDTH{1'b0}};
    end else begin
      if (fire)           begin out_data <= conv_result; out_valid <= 1'b1; end
      else if (out_ready) out_valid <= 1'b0;
    end
  end : pipe

endmodule : {{ module_name }}
