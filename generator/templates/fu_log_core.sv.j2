// {{ module_name }}.sv -- Fabric FU for share group log_core.
// op_list: {{ op_list | join(', ') }}
//   op_sel = 0 -> log(x)    ({{ op_list[0] }})  natural log
//   op_sel = 1 -> log2(x)   ({{ op_list[1] }})
//   op_sel = 2 -> log10(x)  ({{ op_list[2] }})
//   op_sel = 3 -> log1p(x)  ({{ op_list[3] }})  ln(1+x)
//
// Shared log2 core: for x = 2^e * m (m in [1,2)), log2(x) = e + log2(m), with
// log2(m) a COMPILE-TIME MINIMAX POLYNOMIAL (Horner) over f=m-1 in [0,1), baked
// per format. Output scaled by 1 (log2), ln2 (log), 1/log2(10) (log10). log1p
// pre-adds 1.0 via an inline parameterized FP adder, then the ln path. op_sel
// held config. Unary op. Latency 1. PARAMETERIZED (EXP_W, MANT_W): fp32/fp64/bf16.
//
// APPROXIMATE. FTZ. Specials: x<0 -> NaN, x=+/-0 -> -Inf, x=1 -> +0, +Inf -> +Inf;
// log1p(-1) -> -Inf, log1p(x<-1) -> NaN. log1p rel accuracy near 0 limited.

module {{ module_name }} #(
  parameter  int unsigned EXP_W  = {{ fmt.exp_w }},
  parameter  int unsigned MANT_W = {{ fmt.mant_w }},
  localparam int unsigned WIDTH  = EXP_W + MANT_W + 1,
  localparam int unsigned BIAS   = (1 << (EXP_W - 1)) - 1,
  localparam int unsigned EXP_MAX = (1 << EXP_W) - 1,
  localparam int unsigned SIG_W  = MANT_W + 1,
  localparam int unsigned NORM_W = MANT_W + 4,
  localparam int unsigned ALN_W  = MANT_W + 5,
  localparam int unsigned LZW    = $clog2(NORM_W + 1),
  localparam int unsigned ES_W   = EXP_W + 2,
  localparam int unsigned FRAC   = MANT_W + 4,          // poly frac bits (matches generator)
  localparam int unsigned PCW    = FRAC + 4,            // poly coeff width
  localparam int unsigned SCW    = FRAC + 2,            // scale-constant width
  localparam int unsigned LCW    = EXP_W + FRAC + 3,    // log2core / result width (signed)
  localparam int unsigned CLZW   = $clog2(LCW + 1),
  localparam int unsigned LDEG   = {{ poly.log2m_deg }}
) (
  input  logic              clk,
  input  logic              rst_n,
  input  logic [1:0]        op_sel,     // 0={{ op_list[0] }} 1={{ op_list[1] }} 2={{ op_list[2] }} 3={{ op_list[3] }}
  input  logic [WIDTH-1:0]  in_data_0,
  input  logic              in_valid_0,
  output logic              in_ready_0,
  output logic [WIDTH-1:0]  out_data,
  output logic              out_valid,
  input  logic              out_ready
);

  localparam logic [WIDTH-1:0] ONE_F32 = {1'b0, EXP_W'(BIAS), {MANT_W{1'b0}}};   // 1.0
  localparam logic [WIDTH-1:0] QNAN    = {1'b0, {EXP_W{1'b1}}, 1'b1, {(MANT_W-1){1'b0}}};
  localparam logic [WIDTH-1:0] POSINF  = {1'b0, {EXP_W{1'b1}}, {MANT_W{1'b0}}};
  localparam logic [WIDTH-1:0] NEGINF  = {1'b1, {EXP_W{1'b1}}, {MANT_W{1'b0}}};
  localparam logic [SCW-1:0]   LN2        = {{ poly.ln2_lit }};        // ln2 in Q.FRAC
  localparam logic [SCW-1:0]   INVLOG2_10 = {{ poly.invlog2_10_lit }}; // 1/log2(10) in Q.FRAC
  localparam logic [SCW-1:0]   ONE_Q      = {{ poly.one_lit }};        // 1.0 in Q.FRAC
  localparam logic signed [PCW-1:0] LOG2M_C [0:LDEG] = '{ {{ poly.log2m_coef_lits | join(', ') }} };

  function automatic logic [CLZW-1:0] clz(input logic [LCW-1:0] x);
    logic [CLZW-1:0] n; logic f; integer i;
    begin n = '0; f = 1'b0;
      for (i = LCW-1; i >= 0; i = i-1) if (!f) begin if (x[i]) f = 1'b1; else n = n + 1'b1; end
      clz = n;
    end
  endfunction

  function automatic logic [LZW-1:0] lzc(input logic [NORM_W-1:0] x);
    logic [LZW-1:0] n; logic f; integer i;
    begin n = '0; f = 1'b0;
      for (i = NORM_W-1; i >= 0; i = i-1) if (!f) begin if (x[i]) f = 1'b1; else n = n + 1'b1; end
      lzc = n;
    end
  endfunction

  // Inline parameterized IEEE-754 adder (RNE, FTZ) -- used for log1p's (1+x).
  // verilator lint_off UNUSEDSIGNAL
  function automatic logic [WIDTH-1:0] fp_add(input logic [WIDTH-1:0] a, input logic [WIDTH-1:0] b);
    logic sa, sb; logic [EXP_W-1:0] ea, eb; logic [MANT_W-1:0] ma, mb;
    logic an, bn, ai, bi, az, bz; logic [SIG_W-1:0] sga, sgb;
    logic bsgn, ssgn, addop; logic [EXP_W-1:0] bex, df; logic [SIG_W-1:0] bsig, ssig;
    logic [ALN_W-1:0] bm, sm, sal, raw; logic [NORM_W-1:0] nrm; logic stsh, stk;
    logic [LZW-1:0] sh; logic [MANT_W-1:0] m23, mf; logic gd, rup; logic [SIG_W-1:0] mr;
    logic signed [ES_W-1:0] es, es2; logic [WIDTH-1:0] r;
    begin
      sa=a[WIDTH-1]; ea=a[WIDTH-2:MANT_W]; ma=a[MANT_W-1:0];
      sb=b[WIDTH-1]; eb=b[WIDTH-2:MANT_W]; mb=b[MANT_W-1:0];
      an=(&ea)&(|ma); bn=(&eb)&(|mb); ai=(&ea)&(~|ma); bi=(&eb)&(~|mb);
      az=(ea=='0); bz=(eb=='0); sga={1'b1,ma}; sgb={1'b1,mb};
      bsgn='0;ssgn='0;addop='0;bex='0;bsig='0;ssig='0;df='0;bm='0;sm='0;sal='0;raw='0;
      nrm='0;stsh='0;stk='0;sh='0;m23='0;mf='0;gd='0;rup='0;mr='0;es='0;es2='0;
      r = {1'b0,{EXP_W{1'b1}},1'b1,{(MANT_W-1){1'b0}}};
      if (an|bn)              r = {1'b0,{EXP_W{1'b1}},1'b1,{(MANT_W-1){1'b0}}};
      else if (ai&bi)         r = (sa==sb) ? {sa,{EXP_W{1'b1}},{MANT_W{1'b0}}} : {1'b0,{EXP_W{1'b1}},1'b1,{(MANT_W-1){1'b0}}};
      else if (ai)            r = {sa,{EXP_W{1'b1}},{MANT_W{1'b0}}};
      else if (bi)            r = {sb,{EXP_W{1'b1}},{MANT_W{1'b0}}};
      else if (az&bz)         r = {sa&sb,{(WIDTH-1){1'b0}}};
      else if (az)            r = {sb,eb,mb};
      else if (bz)            r = {sa,ea,ma};
      else begin
        if ((ea>eb)|((ea==eb)&(ma>=mb))) begin bsgn=sa;bex=ea;bsig=sga;ssgn=sb;ssig=sgb;df=ea-eb; end
        else begin bsgn=sb;bex=eb;bsig=sgb;ssgn=sa;ssig=sga;df=eb-ea; end
        addop=(bsgn==ssgn); bm={1'b0,bsig,3'b000}; sm={1'b0,ssig,3'b000};
        if (32'(df)>=ALN_W) begin sal='0; stsh=|ssig; end
        else begin sal=sm>>df; stsh=|(sm & ((ALN_W'(1)<<df)-ALN_W'(1))); end
        sal[0]=sal[0]|stsh;
        raw = addop ? (bm+sal) : (bm-sal);
        if (!addop & (raw=='0)) r = {WIDTH{1'b0}};
        else begin
          if (addop & raw[ALN_W-1]) begin nrm=raw[ALN_W-1:1]; es=signed'(ES_W'(bex))+signed'(ES_W'(1)); stk=raw[0]; end
          else if (addop)           begin nrm=raw[NORM_W-1:0]; es=signed'(ES_W'(bex)); stk=1'b0; end
          else begin sh=lzc(raw[NORM_W-1:0]); nrm=raw[NORM_W-1:0]<<sh; es=signed'(ES_W'(bex))-signed'(ES_W'(sh)); stk=1'b0; end
          m23=nrm[MANT_W+2:3]; gd=nrm[2]; stk=stk|nrm[1]|nrm[0];
          rup=gd&(stk|m23[0]); mr={1'b0,m23}+SIG_W'(rup);
          if (mr[SIG_W-1]) begin mf='0; es2=es+signed'(ES_W'(1)); end else begin mf=mr[MANT_W-1:0]; es2=es; end
          if (es2>=signed'(ES_W'(EXP_MAX))) r={bsgn,{EXP_W{1'b1}},{MANT_W{1'b0}}};
          else if (es2<=0)                  r={bsgn,{EXP_W{1'b0}},{MANT_W{1'b0}}};
          else                              r={bsgn,es2[EXP_W-1:0],mf};
        end
      end
      fp_add = r;
    end
  endfunction
  // verilator lint_on UNUSEDSIGNAL

  logic [WIDTH-1:0]  xv;
  logic              svx, nanx, infx, zerox, rsign;
  logic [EXP_W-1:0]  evx;
  logic [MANT_W-1:0] mvx;
  logic signed [15:0] ev, exp_be;
  logic [FRAC-1:0]   f_q;
  logic [SCW-1:0]    scale;
  // verilator lint_off UNUSEDSIGNAL
  logic signed [PCW-1:0]  acc;
  logic signed [2*PCW:0]  pmul;
  logic signed [LCW-1:0]  log2core, res;
  logic signed [LCW+SCW:0] prodm;
  logic [LCW-1:0]         mag, norm;
  logic [MANT_W:0]        mant24;
  // verilator lint_on UNUSEDSIGNAL
  logic [CLZW-1:0]   clz_e;
  logic [MANT_W-1:0] mant, mant_f;
  logic              guard, sticky, roundup;
  logic [WIDTH-1:0]  core_enc, conv_result;
  integer i;

  always_comb begin : datapath
    xv   = (op_sel == 2'd3) ? fp_add(in_data_0, ONE_F32) : in_data_0;
    svx  = xv[WIDTH-1]; evx = xv[WIDTH-2:MANT_W]; mvx = xv[MANT_W-1:0];
    nanx = (&evx) & (|mvx);
    infx = (&evx) & (~|mvx);
    zerox = (evx == '0);

    ev  = signed'(16'(evx)) - signed'(16'(BIAS));
    f_q = {mvx, {(FRAC-MANT_W){1'b0}}};

    // log2(m) via Horner minimax polynomial -> p in [0,1), Q.FRAC
    acc = LOG2M_C[LDEG];
    for (i = LDEG - 1; i >= 0; i = i - 1) begin
      pmul = acc * $signed({1'b0, f_q});
      acc  = PCW'(pmul >>> FRAC) + LOG2M_C[i];
    end

    // log2core = e + log2(m)  (signed Q.FRAC)
    log2core = (signed'(LCW'(ev)) <<< FRAC) + signed'(LCW'(acc));

    // scale: log2 *1, log *ln2, log10 *1/log2(10), log1p *ln2
    case (op_sel)
      2'd1:    scale = ONE_Q;
      2'd2:    scale = INVLOG2_10;
      default: scale = LN2;
    endcase
    prodm = log2core * signed'({1'b0, scale});
    res   = LCW'(prodm >>> FRAC);

    // encode signed Q.FRAC result -> binary32 (RNE)
    rsign = res[LCW-1];
    mag   = rsign ? (~res + 1'b1) : res;
    clz_e = clz(mag);
    norm  = mag << clz_e;
    mant    = norm[LCW-2 -: MANT_W];
    guard   = norm[LCW-2-MANT_W];
    sticky  = |norm[LCW-3-MANT_W : 0];
    roundup = guard & (sticky | mant[0]);
    mant24  = {1'b0, mant} + (MANT_W+1)'(roundup);
    exp_be  = signed'(16'(LCW - 1 - FRAC + BIAS)) - signed'(16'(clz_e))
              + (mant24[MANT_W] ? 16'sd1 : 16'sd0);
    mant_f  = mant24[MANT_W] ? '0 : mant24[MANT_W-1:0];
    if (mag == '0)                  core_enc = {rsign, {(WIDTH-1){1'b0}}};
    else if (exp_be <= 0)           core_enc = {rsign, {EXP_W{1'b0}}, {MANT_W{1'b0}}};
    else if (exp_be >= signed'(16'(EXP_MAX))) core_enc = {rsign, {EXP_W{1'b1}}, {MANT_W{1'b0}}};
    else                            core_enc = {rsign, exp_be[EXP_W-1:0], mant_f};

    // specials
    if (nanx)              conv_result = QNAN;
    else if (svx & ~zerox) conv_result = QNAN;
    else if (zerox)        conv_result = NEGINF;
    else if (infx)         conv_result = POSINF;
    else                   conv_result = core_enc;
  end : datapath

  logic fire;
  assign fire       = in_valid_0 & (~out_valid | out_ready);
  assign in_ready_0 = fire;

  always_ff @(posedge clk) begin : pipe
    if (!rst_n) begin out_valid <= 1'b0; out_data <= {WIDTH{1'b0}}; end
    else begin
      if (fire)           begin out_data <= conv_result; out_valid <= 1'b1; end
      else if (out_ready) out_valid <= 1'b0;
    end
  end : pipe

endmodule : {{ module_name }}
