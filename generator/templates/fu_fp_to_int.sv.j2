// {{ module_name }}.sv -- Fabric FU for share group fp_to_int.
// op_list: {{ op_list | join(', ') }}
//   op_sel = 0 -> out = signed-int(a)     ({{ op_list[0] }})
//   op_sel = 1 -> out = unsigned-int(a)   ({{ op_list[1] }})
//
// One shared IEEE-754-binary32 -> int32 extractor; op_sel selects the signed vs
// unsigned post-processing. Truncates toward zero. op_sel is a held config input.
// Unary op (one data input). Intrinsic latency 1 (registered output).
//
// Structural (decode exponent/mantissa -> shift -> truncate). This DIVERGES from
// loom's behavioral $bitstoshortreal/$rtoi model, which Verilator cannot
// simulate (shortreal unsupported). Out-of-range / NaN / Inf use RISC-V FCVT
// saturation (loom's bare $rtoi leaves these undefined):
//   fptosi: NaN/+overflow -> INT_MAX; -overflow/-Inf -> INT_MIN.
//   fptoui: NaN/+overflow -> UINT_MAX; negative -> 0.
//
// NOTE: targets FP_WIDTH = 32 (binary32) -> INT_WIDTH = 32.

module {{ module_name }} #(
  parameter int unsigned FP_WIDTH  = {{ params.fp_width }},
  parameter int unsigned INT_WIDTH = {{ params.int_width }}
) (
  input  logic                  clk,
  input  logic                  rst_n,

  input  logic                  op_sel,       // 0 = {{ op_list[0] }} (signed), 1 = {{ op_list[1] }} (unsigned)

  input  logic [FP_WIDTH-1:0]   in_data_0,    // IEEE-754 binary32 bits
  input  logic                  in_valid_0,
  output logic                  in_ready_0,

  output logic [INT_WIDTH-1:0]  out_data,     // 32-bit integer
  output logic                  out_valid,
  input  logic                  out_ready
);

  // ---- combinational binary32 -> int32 ----
  logic        sign;
  logic [7:0]  exp;
  logic [22:0] mant;
  logic [23:0] signif;
  logic        is_nan;
  logic [7:0]  eint;          // E = exp - 127 (only meaningful for exp >= 127)
  logic [31:0] mag;           // truncated integer magnitude
  logic [31:0] result;

  always_comb begin : convert
    sign   = in_data_0[31];
    exp    = in_data_0[30:23];
    mant   = in_data_0[22:0];
    signif = {1'b1, mant};
    is_nan = (exp == 8'hFF) & (|mant);

    // truncated magnitude (right shift drops fractional bits = toward zero)
    if (exp < 8'd127) begin : sub_one
      eint = 8'd0;
      mag  = 32'd0;
    end : sub_one
    else begin : ge_one
      eint = exp - 8'd127;
      if (eint >= 8'd23) mag = {8'd0, signif} <<  (eint - 8'd23);
      else               mag = {8'd0, signif} >>  (8'd23 - eint);
    end : ge_one

    result = 32'd0;
    if (op_sel == 1'b0) begin : to_signed
      if (is_nan)             result = 32'h7FFF_FFFF;                          // NaN -> INT_MAX
      else if (exp == 8'hFF)  result = sign ? 32'h8000_0000 : 32'h7FFF_FFFF;   // +/-Inf
      else if (exp < 8'd127)  result = 32'd0;                                  // |v| < 1
      else if (eint >= 8'd31) result = sign ? 32'h8000_0000 : 32'h7FFF_FFFF;   // overflow
      else                    result = sign ? (~mag + 32'd1) : mag;            // E in [0,30]
    end : to_signed
    else begin : to_unsigned
      if (is_nan)             result = 32'hFFFF_FFFF;                          // NaN -> UINT_MAX
      else if (sign)          result = 32'd0;                                  // negative -> 0
      else if (exp == 8'hFF)  result = 32'hFFFF_FFFF;                          // +Inf
      else if (exp < 8'd127)  result = 32'd0;                                  // |v| < 1
      else if (eint >= 8'd32) result = 32'hFFFF_FFFF;                          // overflow
      else                    result = mag;                                    // E in [0,31]
    end : to_unsigned
  end : convert

  // ---- latency-1 handshake (mirrors loom FP FU) ----
  logic fire;
  assign fire       = in_valid_0 & (~out_valid | out_ready);
  assign in_ready_0 = fire;

  always_ff @(posedge clk) begin : pipe_reg
    if (!rst_n) begin : pipe_rst
      out_valid <= 1'b0;
      out_data  <= {INT_WIDTH{1'b0}};
    end : pipe_rst
    else begin : pipe_upd
      if (fire) begin : pipe_fire
        out_data  <= result;
        out_valid <= 1'b1;
      end : pipe_fire
      else if (out_ready) begin : pipe_drain
        out_valid <= 1'b0;
      end : pipe_drain
    end : pipe_upd
  end : pipe_reg

endmodule : {{ module_name }}
